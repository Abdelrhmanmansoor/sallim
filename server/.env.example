# ═══════════════════════════════════════════
# سَلِّم Sallim — Environment Variables
# ═══════════════════════════════════════════

# MongoDB Atlas connection string
# Get yours free at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sallim?retryWrites=true&w=majority

# Server port
PORT=3001

# Frontend URL (for CORS) — update after Vercel deploy
CLIENT_URL=http://localhost:5173

# Backend URL (for self-ping / keep-alive) — update after Render deploy
BACKEND_URL=https://your-backend-url.onrender.com

# Node environment
NODE_ENV=development

# Admin Secret Key (used in Dashboard to view all cards)
ADMIN_SECRET_KEY=your_secret_key_here

# ═══════════════════════════════════════════
# Cloudinary (Image Upload CDN)
# ═══════════════════════════════════════════
# Get your free account at: https://cloudinary.com

# Cloudinary Cloud Name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API Key
CLOUDINARY_API_KEY=your_api_key

# Cloudinary API Secret
CLOUDINARY_API_SECRET=your_api_secret

# ═══════════════════════════════════════════
# PayPal (Payment Gateway)
# ═══════════════════════════════════════════
# Get credentials at: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_ENV=sandbox

# ═══════════════════════════════════════════
# Paymob Egypt (Payment Gateway)
# ═══════════════════════════════════════════
# Get credentials at: https://accept.paymob.com
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID=your_integration_id
PAYMOB_HMAC_SECRET=your_hmac_secret
PAYMOB_IFRAME_ID=your_iframe_id

# SAR to EGP fallback exchange rate (used only if live API fails and no cached rate)
# Live rate fetched automatically from open.er-api.com — no need to set this
# SAR_TO_EGP_FALLBACK=13.16
