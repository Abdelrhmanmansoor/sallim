# ═══════════════════════════════════════════
# سَلِّم Sallim — Environment Variables
# ═══════════════════════════════════════════

# MongoDB Atlas connection string
# Get yours free at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sallim?retryWrites=true&w=majority

# Server port
PORT=3001

# Frontend URL (for CORS and redirects)
CLIENT_URL=https://www.sallim.co

# Backend URL (for webhooks and self-ping)
BACKEND_URL=https://sallim-be.vercel.app

# Node environment
NODE_ENV=development

# Admin Secret Key (used in Dashboard to view all cards)
ADMIN_SECRET_KEY=your_secret_key_here

# ═══════════════════════════════════════════
# Cloudinary (Image Upload CDN)
# ═══════════════════════════════════════════
# Get your free account at: https://cloudinary.com

# Cloudinary Cloud Name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API Key
CLOUDINARY_API_KEY=your_api_key

# Cloudinary API Secret
CLOUDINARY_API_SECRET=your_api_secret

# ═══════════════════════════════════════════
# PayPal (Payment Gateway)
# ═══════════════════════════════════════════
# Get credentials at: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_ENV=sandbox

# ═══════════════════════════════════════════
# Paymob Egypt (Payment Gateway)
# ═══════════════════════════════════════════
# Get credentials at: https://accept.paymob.com
# Flash Integration Documentation: https://developers.paymob.com/paymob-docs/integration-paths/apis

# Paymob API Key (required for Flash Integration)
PAYMOB_API_KEY=your_paymob_api_key

# Paymob Secret Key (for HMAC verification)
PAYMOB_SECRET_KEY=your_paymob_secret_key

# Paymob Public Key (optional, for client-side operations)
PAYMOB_PUBLIC_KEY=your_paymob_public_key

# Paymob Integration ID (use 5577534 for testing)
PAYMOB_INTEGRATION_ID=5577534

# Paymob HMAC Secret (for legacy callback verification)
PAYMOB_HMAC_SECRET=your_hmac_secret

# Paymob iFrame ID (for legacy iframe integration)
PAYMOB_IFRAME_ID=your_iframe_id

# Paymob Mode: 'test' or 'live'
PAYMOB_MODE=test

# SAR to EGP fallback exchange rate (used only if live API fails and no cached rate)
# Live rate fetched automatically from open.er-api.com — no need to set this
# SAR_TO_EGP_FALLBACK=13.16

